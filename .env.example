# ═══════════════════════════════════════════════════════════════════
# BraveAspire AI BDM — Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production
TRACKING_BASE_URL=http://localhost:8000

# ── Database ──────────────────────────────────────────────────────
# SQL Server (default — Windows Authentication / Trusted Connection)
USE_SQLSERVER=true
DB_SERVER=LAPTOP-5LTAD0QS\SQLEXPRESS
DB_NAME=BraveAspireBDM
DB_DRIVER=ODBC+Driver+17+for+SQL+Server
# To override with full URL:
# DATABASE_URL=mssql+pyodbc://SERVER\INSTANCE/DB?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes
# To fall back to SQLite (dev only):
# USE_SQLSERVER=false

# ── AI Provider ───────────────────────────────────────────────────
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Groq Cloud AI (console.groq.com) ──────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── SMS OTP (Twilio — twilio.com/console) ─────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ── Email / SMTP ──────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=your@gmail.com
FROM_NAME=BraveAspire AI BDM

# ── IMAP (inbox reply detection) ──────────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your@gmail.com
IMAP_PASSWORD=your_app_password

# ── Lead Scraping APIs ────────────────────────────────────────────
APOLLO_API_KEY=your_apollo_api_key_here
GOOGLE_MAPS_API_KEY=AIza_your_google_maps_api_key
CRUNCHBASE_API_KEY=your_crunchbase_api_key_here
PROXYCURL_API_KEY=your_proxycurl_api_key_here
HUNTER_API_KEY=your_hunter_api_key

# ── Stripe Billing (dashboard.stripe.com) ─────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Default Sender Profile ────────────────────────────────────────
SENDER_NAME=BraveAspire Team
SENDER_COMPANY=BraveAspire
SERVICES=custom software development & AI solutions
